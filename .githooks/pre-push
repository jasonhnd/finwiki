#!/bin/sh
# FinWiki pre-push gate. Blocks a push when the public release surface is not
# publishable under the repository rules.
#
#     bun tools/release.ts --check --strict
#
# Install:
#     cp .githooks/pre-push .git/hooks/pre-push
# or:
#     git config core.hooksPath .githooks
#
# Bypass a single push only when intentionally handling an emergency:
#     git push --no-verify

cat > /dev/null

BUN=""
if [ -n "$FINWIKI_BUN" ]; then
  BUN="$FINWIKI_BUN"
elif command -v bun >/dev/null 2>&1; then
  BUN=bun
elif [ -n "$USERPROFILE" ] && [ -x "$USERPROFILE/.bun/bin/bun.exe" ]; then
  BUN="$USERPROFILE/.bun/bin/bun.exe"
elif [ -n "$HOME" ] && [ -x "$HOME/.bun/bin/bun" ]; then
  BUN="$HOME/.bun/bin/bun"
fi

if [ -z "$BUN" ]; then
  {
    echo "pre-push BLOCKED: Bun was not found for the FinWiki release check."
    echo "  Put bun on PATH, set FINWIKI_BUN=<path>, or bypass once: git push --no-verify"
  } >&2
  exit 1
fi

ROOT=$(git rev-parse --show-toplevel) || exit 0
cd "$ROOT" || exit 0

echo "pre-push: FinWiki Bun release check (link audit + count drift)..."
"$BUN" tools/release.ts --check --strict
status=$?

if [ "$status" -ne 0 ]; then
  {
    echo ""
    echo "pre-push BLOCKED (release check exit $status):"
    echo "  Fix links or sync README/index/discovery first."
    echo "  Fix:    bun tools/release.ts --write   (then commit the synced files)"
    echo "  Bypass: git push --no-verify   (not recommended)"
  } >&2
  exit 1
fi

echo "pre-push: OK - links resolve and counts are in sync."
exit 0
