{
  "name": "finwiki",
  "private": true,
  "type": "module",
  "scripts": {
    "ai:discovery": "bun tools/generate_ai_discovery.ts",
    "ai:audit": "bun tools/txt_route_audit.ts",
    "docs:audit": "bun tools/docs_link_audit.ts",
    "docs:stale": "bun tools/active_doc_stale_scan.ts",
    "surface:drift": "bun tools/generated_surface_drift_scan.ts",
    "footer:timestamp": "bun tools/update_footer_timestamp.ts",
    "i18n:status": "bun tools/i18n_status.ts",
    "index:audit": "bun tools/index_count_audit.ts",
    "entity:audit": "bun tools/entity_graph_audit.ts",
    "factual:audit": "bun tools/factual_consistency_audit.ts",
    "provenance:audit": "bun tools/provenance_completeness_audit.ts",
    "html:check": "bun tools/check_duplicate_html_ids.ts site/dist",
    "release:check": "bun tools/release.ts --check --strict",
    "release:write": "bun tools/release.ts --write",
    "wiki:audit": "bun tools/wiki_link_audit.ts --report wiki-link-improvement-plan.md --fail-on-issues",
    "wiki:audit:ci": "bun tools/wiki_link_audit.ts --fail-on-issues",
    "publish:assemble": "bun tools/assemble_static_publish.ts --out _vercel_public",
    "vercel:build": "bun tools/vercel_build.ts"
  },
  "version": "1.0.0",
  "description": "FinWiki は、金融、決済、ステーブルコイン、暗号資産、資本市場、日本の金融機関、政策金融、公開企業・公開人物の戦略ケースを扱う Markdown ナレッジベースです。主なリンク形式は Obsidian の `[[wikilink]]` で、全体入口は [INDEX.md](INDEX.md) です。",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonhnd/finwiki.git"
  },
