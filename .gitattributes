# FinWiki line-ending and binary policy
#
# Stable cross-platform behavior: every text file is stored AND checked out
# with LF line endings, regardless of OS (Windows / macOS / Linux). This
# prevents the "473KB vs 483KB" CRLF/LF drift we saw between Windows local
# checkouts and the LF-normalized version that GitHub Pages serves.
#
# `text=auto` lets Git auto-detect text vs binary by content.
# `eol=lf` overrides the local `core.autocrlf=true` setting so Windows
# checkouts no longer swap LF -> CRLF on smudge.

* text=auto eol=lf

# Explicit text patterns (defensive: in case auto-detect misclassifies)
*.md       text eol=lf
*.txt      text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.js       text eol=lf
*.json     text eol=lf
*.xml      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.toml     text eol=lf
*.ini      text eol=lf

# Explicit binary patterns
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.ttf      binary
*.ttc      binary
*.otf      binary
*.woff     binary
*.woff2    binary

# Linguist hints — keep the generated AI-discovery surfaces and per-entry
# JSON files visible in language stats but not counted as primary code.
ai-index.json     linguist-generated=true
llms-full.txt     linguist-generated=true
sitemap.xml       linguist-generated=true
api/**            linguist-generated=true
wiki-link-improvement-plan.md linguist-generated=true
