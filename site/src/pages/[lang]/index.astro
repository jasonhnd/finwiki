---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { t, u, langCodes, type Lang } from '../../i18n/ui';
import { domainDescription, domainName } from '../../i18n/domains';
import { domainGroups, groupDescription, groupName } from '../../i18n/groups';
import { entryDomain, entryRoute, i18nEntryId } from '../../lib/routes';
import { isoDate } from '../../lib/format';
import { localizedTitle } from '../../lib/siteIndex.mjs';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const all = await getCollection('entries');
const translations = await getCollection('i18n');
const i18nMap = new Map(translations.map((entry) => [entry.id, entry]));
const entryByRoute = new Map(all.map((entry) => [entryRoute(entry), entry]));

const counts = new Map<string, number>();
for (const e of all) {
  const d = entryDomain(e);
  counts.set(d, (counts.get(d) ?? 0) + 1);
}

function titleFor(entry: (typeof all)[number]): string {
  const tr = i18nMap.get(i18nEntryId(lang, entry));
  return String(tr?.data?.title || localizedTitle(lang, entryRoute(entry)) || entry.data.title || entryRoute(entry));
}

const latestReviewed = [...all]
  .filter((e) => e.data.last_updated)
  .sort((a, b) => isoDate(b.data.last_updated).localeCompare(isoDate(a.data.last_updated)))
  .slice(0, 6);

const canonicalRouteIds = [
  'banking/japan-banking-license-tier-comparison-matrix',
  'payments/japan-payment-clearing-and-settlement-infrastructure',
  'securities/japan-market-infrastructure-map',
  'exchanges/jp-vasp-regulatory-timeline',
  'financial-regulators/fsa',
  'insurance/global-solvency-framework-comparison-matrix',
];

const canonicalRoutes = canonicalRouteIds
  .map((route) => entryByRoute.get(route))
  .filter(Boolean) as (typeof all)[number][];

const entryCount = all.length;
const domainCount = counts.size;
const translatedCount = translations.filter((e) => e.id.startsWith(`${lang}/`)).length;
---
<Base lang={lang} active="home">
  <section class="home-hero container">
    <p class="eyebrow">FinWiki</p>
    <h1 class="home-hero__title">{t(lang, 'home.headline')}</h1>
    <p class="lead home-hero__deck">{t(lang, 'home.deck')}</p>

    <div class="home-search" aria-label={t(lang, 'home.searchKicker')}>
      <span class="home-search__label">{t(lang, 'home.searchKicker')}</span>
      <pagefind-modal-trigger class="pf-hero" placeholder={t(lang, 'home.searchPlaceholder')} shortcut="mod+k"></pagefind-modal-trigger>
    </div>

    <div class="home-proof" aria-label={t(lang, 'home.corpusProof')}>
      <span><b>{entryCount.toLocaleString('en-US')}</b> {t(lang, 'domain.entries')}</span>
      <span><b>{domainCount}</b> {t(lang, 'nav.domains')}</span>
      {lang !== 'ja' && <span><b>{translatedCount.toLocaleString('en-US')}</b> {t(lang, 'domain.translated')}</span>}
    </div>
  </section>

  <section class="container home-block">
    <div class="home-block__head">
      <div>
        <p class="eyebrow">{t(lang, 'home.startReading')}</p>
        <h2 class="section-title">{t(lang, 'home.latestReviewed')}</h2>
      </div>
      <p class="muted home-block__note">{t(lang, 'home.latestReviewedNote')}</p>
    </div>
    <div class="review-strip">
      {latestReviewed.map((entry) => {
        const route = entryRoute(entry);
        const domain = entryDomain(entry);
        return (
          <a class="review-card" href={u(lang, `${route}/`)}>
            <span class="review-card__domain">{domainName(domain, lang)}</span>
            <span class="review-card__title">{titleFor(entry)}</span>
            <span class="review-card__meta">{t(lang, 'entry.updated')} {isoDate(entry.data.last_updated)}</span>
          </a>
        );
      })}
    </div>
  </section>

  <section class="container home-block">
    <div class="home-block__head">
      <div>
        <p class="eyebrow">{t(lang, 'home.canonicalRoutes')}</p>
        <h2 class="section-title">{t(lang, 'home.canonicalRoutes')}</h2>
      </div>
      <p class="muted home-block__note">{t(lang, 'home.canonicalRoutesNote')}</p>
    </div>
    <div class="canonical-strip">
      {canonicalRoutes.map((entry) => {
        const route = entryRoute(entry);
        const domain = entryDomain(entry);
        return (
          <a class="canonical-route" href={u(lang, `${route}/`)}>
            <span class="canonical-route__domain">{domainName(domain, lang)}</span>
            <span class="canonical-route__title">{titleFor(entry)}</span>
            <code>{route}</code>
          </a>
        );
      })}
    </div>
  </section>

  <section class="container home-block">
    <div class="home-block__head">
      <div>
        <p class="eyebrow">{t(lang, 'nav.domains')}</p>
        <h2 class="section-title">{t(lang, 'home.guidedTaxonomy')}</h2>
      </div>
      <div class="home-block__actions">
        <p class="muted home-block__note">{t(lang, 'home.guidedTaxonomyNote')}</p>
        <a class="btn" href={u(lang, 'domains/')}>{t(lang, 'home.viewAllDomains')} →</a>
      </div>
    </div>
    <div class="taxonomy-grid">
      {domainGroups.map((group) => {
        const domains = group.domains.filter((domain) => counts.has(domain));
        if (!domains.length) return null;
        const total = domains.reduce((sum, domain) => sum + (counts.get(domain) ?? 0), 0);
        return (
          <section class="taxonomy-group">
            <div class="taxonomy-group__head">
              <h3>{groupName(group, lang)}</h3>
              <span>{total.toLocaleString('en-US')}</span>
            </div>
            <p>{groupDescription(group, lang)}</p>
            <div class="taxonomy-group__domains">
              {domains.slice(0, 5).map((domain) => (
                <a href={u(lang, `domains/${domain}/`)}>
                  <span>{domainName(domain, lang)}</span>
                  <small>{domainDescription(domain, lang)}</small>
                  <b>{counts.get(domain)}</b>
                </a>
              ))}
            </div>
          </section>
        );
      })}
    </div>
  </section>

  <section class="container home-block">
    <div class="ai-band">
      <div>
        <p class="eyebrow">{t(lang, 'home.aiTechLabel')}</p>
        <h2 class="section-title">{t(lang, 'home.ai')}</h2>
        <p class="muted ai-band__note">{t(lang, 'home.aiNote')}</p>
      </div>
      <div class="ai-links">
        <a href="/llms.txt"><b>llms.txt</b><span>{t(lang, 'home.aiGuide')}</span></a>
        <a href="/llms-full.txt"><b>llms-full.txt</b><span>{t(lang, 'home.aiManifest')}</span></a>
        <a href="/ai-index.json"><b>ai-index.json</b><span>{t(lang, 'home.aiIndex')}</span></a>
        <a href="/sitemap.xml"><b>sitemap.xml</b><span>{t(lang, 'home.aiSitemap')}</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .home-hero {
    padding-top: clamp(2.6rem, 1.6rem + 4vw, 5.6rem);
    padding-bottom: var(--sp-6);
  }
  .home-hero__title {
    max-width: 18ch;
    margin: 0 0 1rem;
    font-size: var(--fs-2xl);
    line-height: 1.08;
  }
  html[lang="en"] .home-hero__title {
    max-width: 20ch;
  }
  html[lang="zh"] .home-hero__title {
    max-width: 19ch;
  }
  .home-hero__deck {
    margin: 0;
    max-width: var(--measure-lead);
  }
  .home-search {
    display: grid;
    gap: 0.45rem;
    max-width: 38rem;
    margin-top: 1.55rem;
  }
  .home-search__label {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pf-hero {
    display: block;
    --pagefind-ui-scale: 1.05;
  }
  .home-proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.4rem;
    margin-top: 1.3rem;
    color: var(--muted);
    font-size: var(--fs-sm);
  }
  .home-proof b {
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1;
    margin-right: 0.25rem;
  }

  .home-block {
    padding-top: var(--gap-section);
  }
  .home-block__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.2rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .home-block__head .section-title {
    margin: 0;
  }
  .home-block__note {
    max-width: 34rem;
    margin: 0;
    font-size: var(--fs-sm);
  }
  .home-block__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .review-strip,
  .canonical-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--line);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .review-card,
  .canonical-route {
    display: grid;
    align-content: start;
    gap: 0.35rem;
    min-width: 0;
    min-height: 8.8rem;
    padding: 1rem;
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
  }
  .review-card:hover,
  .canonical-route:hover {
    background: var(--surface);
  }
  .review-card__domain,
  .canonical-route__domain {
    color: var(--accent);
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .review-card__title,
  .canonical-route__title {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: var(--fs-md);
    line-height: 1.25;
    overflow-wrap: anywhere;
  }
  .review-card__meta {
    margin-top: auto;
    color: var(--muted);
    font-size: var(--fs-xs);
  }
  .canonical-route code {
    margin-top: auto;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .taxonomy-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.35rem 1.5rem;
  }
  .taxonomy-group {
    min-width: 0;
    border-top: 2px solid var(--line);
    padding-top: 0.85rem;
  }
  .taxonomy-group__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
  }
  .taxonomy-group h3 {
    margin: 0;
    font-size: var(--fs-md);
  }
  .taxonomy-group__head span {
    color: var(--muted);
    font-size: var(--fs-xs);
    font-variant-numeric: tabular-nums;
  }
  .taxonomy-group p {
    margin: 0.45rem 0 0.8rem;
    color: var(--ink-2);
    font-size: var(--fs-sm);
    line-height: 1.55;
  }
  .taxonomy-group__domains {
    display: grid;
    gap: 0.3rem;
  }
  .taxonomy-group__domains a {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.15rem 0.75rem;
    min-width: 0;
    padding: 0.45rem 0;
    color: var(--ink);
    text-decoration: none;
    border-top: 1px solid var(--line);
  }
  .taxonomy-group__domains a:hover {
    color: var(--accent-2);
  }
  .taxonomy-group__domains span {
    font-weight: 650;
    overflow-wrap: anywhere;
  }
  .taxonomy-group__domains small {
    grid-column: 1 / -1;
    color: var(--muted);
    font-size: var(--fs-xs);
    line-height: 1.45;
  }
  .taxonomy-group__domains b {
    color: var(--muted);
    font-size: var(--fs-xs);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }

  .ai-band {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 1.35fr);
    gap: 1.5rem 2.5rem;
    align-items: center;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--r);
    padding: clamp(1.35rem, 1rem + 2vw, 2.35rem);
  }
  .ai-band .section-title {
    margin: 0;
  }
  .ai-band__note {
    margin: 0.55rem 0 0;
    font-size: var(--fs-sm);
  }
  .ai-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }
  .ai-links a {
    display: grid;
    gap: 0.15rem;
    min-width: 0;
    padding: 0.72rem 0.85rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    text-decoration: none;
  }
  .ai-links a:hover {
    border-color: var(--accent);
  }
  .ai-links b {
    color: var(--accent-2);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    overflow-wrap: anywhere;
  }
  .ai-links span {
    color: var(--muted);
    font-size: var(--fs-xs);
  }

  @media (max-width: 940px) {
    .review-strip,
    .canonical-strip,
    .taxonomy-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .ai-band {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 620px) {
    .review-strip,
    .canonical-strip,
    .taxonomy-grid {
      grid-template-columns: 1fr;
    }
    .home-block__actions {
      justify-content: flex-start;
    }
  }
  @media (max-width: 460px) {
    .ai-links {
      grid-template-columns: 1fr;
    }
  }
</style>
