---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { t, u, langCodes, type Lang } from '../../i18n/ui';
import { domainName } from '../../i18n/domains';
import { entryDomain } from '../../lib/routes';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const all = await getCollection('entries');
const counts = new Map<string, number>();
for (const e of all) {
  const d = entryDomain(e);
  counts.set(d, (counts.get(d) ?? 0) + 1);
}
const domains = [...counts.entries()].sort((a, b) => b[1] - a[1]);
---
<Base lang={lang}>
  <h1>{t(lang, 'site.title')}</h1>
  <p class="tagline">{t(lang, 'site.tagline')}</p>
  <p class="intro">{t(lang, 'home.intro')}</p>

  <div class="stats">
    <a class="stat" href={u(lang, 'browse/')}><strong>{all.length}</strong> entries</a>
    <a class="stat" href={u(lang, 'domains/')}><strong>{domains.length}</strong> domains</a>
  </div>

  <h2 class="sec">{t(lang, 'nav.domains')}</h2>
  <div class="grid">
    {domains.map(([d, n]) => (
      <a class="card" href={u(lang, `domains/${d.toLowerCase()}/`)}>
        <span class="d">{domainName(d, lang)}</span>
        <span class="n">{n}</span>
      </a>
    ))}
  </div>

  <h2 class="sec">{t(lang, 'home.ai')}</h2>
  <ul class="ai">
    <li><a href="/llms.txt">llms.txt</a></li>
    <li><a href="/llms-full.txt">llms-full.txt</a></li>
    <li><a href="/ai-index.json">ai-index.json</a></li>
  </ul>
</Base>

<style>
  h1 { font-size: clamp(1.8rem, 1.2rem + 2vw, 2.6rem); margin: 0 0 0.3rem; letter-spacing: -0.02em; }
  .tagline { color: var(--muted); margin: 0 0 1rem; font-size: 1.05rem; }
  .intro { font-size: 1rem; }
  .stats { display: flex; gap: 0.7rem; margin: 1.5rem 0; }
  .stat { border: 1px solid var(--line); border-radius: 10px; padding: 0.45rem 0.9rem; text-decoration: none; color: var(--fg); font-size: 0.85rem; }
  .stat strong { color: var(--accent); font-size: 1.15rem; }
  .sec { font-size: 1.15rem; margin: 2rem 0 0.8rem; padding-bottom: 0.3rem; border-bottom: 1px solid var(--line); }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 0.6rem; }
  .card { display: flex; justify-content: space-between; align-items: center; border: 1px solid var(--line); border-radius: 10px; padding: 0.6rem 0.9rem; text-decoration: none; color: var(--fg); background: var(--soft); transition: border-color 0.15s; }
  .card:hover { border-color: var(--accent); }
  .card .d { font-weight: 600; font-size: 0.9rem; }
  .card .n { color: var(--muted); font-size: 0.85rem; }
  .ai { columns: 2; font-size: 0.9rem; margin: 0; }
  .ai a { color: var(--accent); }
</style>
