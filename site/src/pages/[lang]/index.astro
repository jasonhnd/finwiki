---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { t, u, langCodes, type Lang } from '../../i18n/ui';
import { domainName } from '../../i18n/domains';
import { domainGroups, groupName } from '../../i18n/groups';
import { entryDomain, entryRoute, i18nEntryId } from '../../lib/routes';
import { isoDate } from '../../lib/format';
import { localizedTitle } from '../../lib/siteIndex.mjs';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const all = await getCollection('entries');
const translations = await getCollection('i18n');
const i18nMap = new Map(translations.map((entry) => [entry.id, entry]));

const counts = new Map<string, number>();
for (const e of all) {
  const d = entryDomain(e);
  counts.set(d, (counts.get(d) ?? 0) + 1);
}

function titleFor(entry: (typeof all)[number]): string {
  const tr = i18nMap.get(i18nEntryId(lang, entry));
  return String(tr?.data?.title || localizedTitle(lang, entryRoute(entry)) || entry.data.title || entryRoute(entry));
}

const recent = [...all]
  .filter((e) => e.data.last_updated)
  .sort((a, b) => isoDate(b.data.last_updated).localeCompare(isoDate(a.data.last_updated)))
  .slice(0, 8);

const entryCount = all.length;
const domainCount = counts.size;
const translatedCount = translations.filter((e) => e.id.startsWith(`${lang}/`)).length;
---
<Base lang={lang} active="home">
  <section class="hero container">
    <p class="eyebrow">FinWiki</p>
    <h1 class="hero__title">{t(lang, 'site.tagline')}</h1>
    <p class="lead hero__lead">{t(lang, 'home.intro')}</p>

    <pagefind-modal-trigger class="pf-hero" placeholder={t(lang, 'home.searchPlaceholder')} shortcut="mod+k"></pagefind-modal-trigger>

    <div class="hero__stats">
      <span><b>{entryCount.toLocaleString('en-US')}</b> {t(lang, 'domain.entries')}</span>
      <span><b>{domainCount}</b> {t(lang, 'nav.domains')}</span>
      {lang !== 'ja' && <span><b>{translatedCount.toLocaleString('en-US')}</b> {t(lang, 'domain.translated')}</span>}
    </div>
  </section>

  <section class="container block">
    <div class="block__head">
      <div>
        <p class="eyebrow">{t(lang, 'home.startReading')}</p>
        <h2 class="section-title">{t(lang, 'home.recent')}</h2>
      </div>
      <p class="muted block__note">{t(lang, 'home.recentNote')}</p>
    </div>
    <div class="recent-grid">
      {recent.map((e) => {
        const d = entryDomain(e);
        return (
          <a class="card" href={u(lang, `${entryRoute(e)}/`)}>
            <span class="card__kicker">{domainName(d, lang)}</span>
            <span class="card__title">{titleFor(e)}</span>
            <span class="card__meta">{t(lang, 'entry.updated')} {isoDate(e.data.last_updated)}</span>
          </a>
        );
      })}
    </div>
  </section>

  <section class="container block">
    <div class="block__head">
      <div>
        <p class="eyebrow">{t(lang, 'nav.domains')}</p>
        <h2 class="section-title">{t(lang, 'home.domainMap')}</h2>
      </div>
      <a class="btn block__cta" href={u(lang, 'domains/')}>{t(lang, 'home.viewAllDomains')} →</a>
    </div>
    <div class="groups">
      {domainGroups.map((g) => {
        const ds = g.domains.filter((d) => counts.has(d));
        if (!ds.length) return null;
        return (
          <div class="group">
            <h3 class="group__name">{groupName(g, lang)}</h3>
            <div class="group__domains">
              {ds.map((d) => (
                <a class="dpill" href={u(lang, `domains/${d}/`)}>
                  <span>{domainName(d, lang)}</span>
                  <b>{counts.get(d)}</b>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="container block">
    <div class="ai-band">
      <div>
        <p class="eyebrow">{t(lang, 'nav.ai')}</p>
        <h2 class="section-title">{t(lang, 'home.ai')}</h2>
        <p class="muted ai-band__note">{t(lang, 'home.aiNote')}</p>
      </div>
      <div class="ai-links">
        <a href="/llms.txt"><b>llms.txt</b><span>{t(lang, 'home.aiGuide')}</span></a>
        <a href="/llms-full.txt"><b>llms-full.txt</b><span>{t(lang, 'home.aiManifest')}</span></a>
        <a href="/ai-index.json"><b>ai-index.json</b><span>{t(lang, 'home.aiIndex')}</span></a>
        <a href="/sitemap.xml"><b>sitemap.xml</b><span>{t(lang, 'home.aiSitemap')}</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-top: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    padding-bottom: var(--sp-5);
  }
  .hero__title {
    font-size: var(--fs-2xl);
    line-height: 1.1;
    margin: 0 0 1rem;
    max-width: 22ch;
  }
  .hero__lead {
    margin: 0 0 1.6rem;
  }
  .pf-hero {
    display: block;
    max-width: 36rem;
    --pagefind-ui-scale: 1.05;
  }
  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 1.6rem;
    color: var(--muted);
    font-size: var(--fs-sm);
  }
  .hero__stats b {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--accent);
    margin-right: 0.3rem;
  }

  .block {
    padding-top: var(--gap-section);
  }
  .block__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.4rem;
    flex-wrap: wrap;
  }
  .block__head .section-title {
    margin: 0;
  }
  .block__note {
    font-size: var(--fs-sm);
    margin: 0;
  }
  .block__cta {
    flex: none;
  }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 1rem;
  }
  .recent-grid .card {
    min-height: 8.5rem;
  }

  .groups {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1.5rem 2rem;
  }
  .group__name {
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--ink-2);
    margin: 0 0 0.7rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--line);
  }
  .group__domains {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .dpill {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    border-radius: var(--r);
    text-decoration: none;
    color: var(--ink);
    transition: background var(--dur) var(--ease);
  }
  .dpill:hover {
    background: var(--surface-2);
  }
  .dpill b {
    color: var(--muted);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .ai-band {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 1.5rem 2.5rem;
    align-items: center;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: clamp(1.5rem, 1rem + 2vw, 2.5rem);
  }
  .ai-band .section-title {
    margin: 0;
  }
  .ai-band__note {
    font-size: var(--fs-sm);
    margin: 0.6rem 0 0;
  }
  .ai-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.7rem;
  }
  .ai-links a {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.7rem 0.9rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    text-decoration: none;
  }
  .ai-links a:hover {
    border-color: var(--accent);
  }
  .ai-links b {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--accent-2);
  }
  .ai-links span {
    font-size: var(--fs-xs);
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .ai-band {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 460px) {
    .ai-links {
      grid-template-columns: 1fr;
    }
  }
</style>
