---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { t, u, langCodes, type Lang } from '../../../i18n/ui';
import { domainName } from '../../../i18n/domains';
import { domainGroups, groupName } from '../../../i18n/groups';
import { entryDomain } from '../../../lib/routes';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const entries = await getCollection('entries');
const counts = new Map<string, number>();
for (const entry of entries) {
  const domain = entryDomain(entry);
  counts.set(domain, (counts.get(domain) ?? 0) + 1);
}
const note = t(lang, 'domains.note')
  .replace('{entries}', entries.length.toLocaleString('en-US'))
  .replace('{domains}', String(counts.size));
---
<Base lang={lang} title={t(lang, 'domains.title')} active="domains">
  <div class="container domains">
    <header class="domains__head">
      <p class="eyebrow">{t(lang, 'nav.domains')}</p>
      <h1>{t(lang, 'domains.title')}</h1>
      <p class="muted">{note}</p>
    </header>

    <div class="domains__groups">
      {domainGroups.map((g) => {
        const ds = g.domains.filter((d) => counts.has(d));
        if (!ds.length) return null;
        const total = ds.reduce((sum, d) => sum + (counts.get(d) ?? 0), 0);
        return (
          <section class="dgroup">
            <div class="dgroup__head">
              <h2>{groupName(g, lang)}</h2>
              <span class="muted">{total.toLocaleString('en-US')}</span>
            </div>
            <div class="dgroup__grid">
              {ds.map((d) => (
                <a class="card dcard" href={u(lang, `domains/${d}/`)}>
                  <span class="dcard__name">{domainName(d, lang)}</span>
                  <span class="dcard__count">{(counts.get(d) ?? 0).toLocaleString('en-US')}</span>
                </a>
              ))}
            </div>
          </section>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .domains {
    padding-top: var(--sp-6);
  }
  .domains__head {
    margin-bottom: var(--sp-6);
  }
  .domains__head h1 {
    font-size: var(--fs-xl);
    margin: 0 0 0.3rem;
  }
  .domains__groups {
    display: flex;
    flex-direction: column;
    gap: var(--sp-7);
  }
  .dgroup__head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin-bottom: 1rem;
  }
  .dgroup__head h2 {
    font-size: var(--fs-md);
    margin: 0;
  }
  .dgroup__head .muted {
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-sm);
  }
  .dgroup__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
    gap: 0.75rem;
  }
  .dcard {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
  }
  .dcard__name {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 600;
  }
  .dcard__count {
    color: var(--accent);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
</style>
