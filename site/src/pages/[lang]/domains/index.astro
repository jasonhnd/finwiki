---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { t, u, langCodes, type Lang } from '../../../i18n/ui';
import { domainDescription, domainName } from '../../../i18n/domains';
import { domainGroups, groupDescription, groupName } from '../../../i18n/groups';
import { entryDomain } from '../../../lib/routes';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const entries = await getCollection('entries');
const counts = new Map<string, number>();
for (const entry of entries) {
  const domain = entryDomain(entry);
  counts.set(domain, (counts.get(domain) ?? 0) + 1);
}
const note = t(lang, 'domains.note')
  .replace('{entries}', entries.length.toLocaleString('en-US'))
  .replace('{domains}', String(counts.size));
---
<Base lang={lang} title={t(lang, 'domains.title')} active="domains">
  <div class="container domains">
    <header class="domains__head">
      <p class="eyebrow">{t(lang, 'nav.domains')}</p>
      <h1>{t(lang, 'domains.title')}</h1>
      <p class="domains__deck">{t(lang, 'domains.deck')}</p>
      <p class="domains__note">{note}</p>
    </header>

    <div class="domains__groups">
      {domainGroups.map((group) => {
        const domains = group.domains.filter((domain) => counts.has(domain));
        if (!domains.length) return null;
        const total = domains.reduce((sum, domain) => sum + (counts.get(domain) ?? 0), 0);
        return (
          <section class="domain-section">
            <div class="domain-section__intro">
              <div>
                <p class="eyebrow">{group.id}</p>
                <h2>{groupName(group, lang)}</h2>
              </div>
              <span class="domain-section__count" aria-label={t(lang, 'domains.groupEntryCount')}>
                {total.toLocaleString('en-US')}
              </span>
            </div>
            <p class="domain-section__description">{groupDescription(group, lang)}</p>
            <div class="domain-section__grid">
              {domains.map((domain) => (
                <a class="domain-card" href={u(lang, `domains/${domain}/`)}>
                  <span class="domain-card__name">{domainName(domain, lang)}</span>
                  <span class="domain-card__description">{domainDescription(domain, lang)}</span>
                  <span class="domain-card__count">{(counts.get(domain) ?? 0).toLocaleString('en-US')}</span>
                </a>
              ))}
            </div>
          </section>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .domains {
    padding-top: var(--sp-7);
  }
  .domains__head {
    max-width: var(--measure-lead);
    margin-bottom: var(--sp-7);
  }
  .domains__head h1 {
    margin: 0 0 0.65rem;
    font-size: var(--fs-2xl);
    line-height: 1.1;
  }
  .domains__deck {
    margin: 0;
    color: var(--ink-2);
    font-size: var(--fs-md);
    line-height: 1.55;
  }
  .domains__note {
    margin: 1rem 0 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }
  .domains__groups {
    display: flex;
    flex-direction: column;
    gap: var(--gap-section);
  }

  .domain-section {
    min-width: 0;
    border-top: 1px solid var(--line);
    padding-top: 1.1rem;
  }
  .domain-section__intro {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.55rem;
  }
  .domain-section__intro .eyebrow {
    margin-bottom: 0.35rem;
  }
  .domain-section__intro h2 {
    margin: 0;
    font-size: var(--fs-lg);
  }
  .domain-section__count {
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: var(--r-pill);
    padding: 0.16rem 0.65rem;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-variant-numeric: tabular-nums;
    line-height: 1.5;
  }
  .domain-section__description {
    max-width: var(--measure-lead);
    margin: 0 0 1.15rem;
    color: var(--ink-2);
    font-size: var(--fs-sm);
    line-height: 1.6;
  }
  .domain-section__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    gap: 0;
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }
  .domain-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.35rem 0.8rem;
    min-width: 0;
    min-height: 8rem;
    padding: 1rem;
    background: var(--paper);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    color: var(--ink);
    text-decoration: none;
  }
  .domain-card:hover {
    background: var(--surface);
  }
  .domain-card__name {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    line-height: 1.22;
    overflow-wrap: anywhere;
  }
  .domain-card__description {
    grid-column: 1 / -1;
    color: var(--ink-2);
    font-size: var(--fs-sm);
    line-height: 1.5;
    overflow-wrap: anywhere;
  }
  .domain-card__count {
    justify-self: start;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: var(--r-pill);
    padding: 0.1rem 0.55rem;
    font-size: var(--fs-xs);
    font-variant-numeric: tabular-nums;
    font-weight: 650;
    line-height: 1.6;
  }

  @media (max-width: 560px) {
    .domain-section__intro {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
