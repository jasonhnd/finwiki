---
import { getCollection } from 'astro:content';
import { domainName, domainNames } from '../i18n/domains';

const entries = await getCollection('entries');
const translations = await getCollection('i18n');

const counts = new Map<string, number>();
const knownDomains = new Set(Object.keys(domainNames));
for (const entry of entries) {
  const domain = entry.id.split('/')[0].toLowerCase();
  if (!knownDomains.has(domain)) continue;
  counts.set(domain, (counts.get(domain) ?? 0) + 1);
}

const featured = ['japanfg', 'fintech', 'exchanges', 'payments', 'insurance', 'derivatives'];
const featuredDomains = featured
  .filter((domain) => counts.has(domain))
  .map((domain) => ({ domain, count: counts.get(domain)! }));

const zhCount = translations.filter((entry) => entry.id.startsWith('zh/')).length;
const enCount = translations.filter((entry) => entry.id.startsWith('en/')).length;

const domainCount = counts.size;
const entryCount = entries.length;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>FinWiki | Public Financial Knowledge Graph</title>
    <meta
      name="description"
      content="FinWiki is a trilingual public-source financial knowledge graph for humans and AI."
    />
    <link rel="alternate" hreflang="ja" href="/ja/" />
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="alternate" hreflang="zh" href="/zh/" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <meta property="og:title" content="FinWiki" />
    <meta property="og:description" content="Public-source financial knowledge graph for humans and AI." />
    <meta property="og:image" content="/og-image.png" />
  </head>
  <body>
    <header class="topbar" aria-label="Primary">
      <a class="brand" href="/">FinWiki</a>
      <nav class="topnav" aria-label="Language and resource links">
        <a href="/ja/">日本語</a>
        <a href="/en/">English</a>
        <a href="/zh/">中文</a>
        <a href="/llms.txt">AI</a>
      </nav>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="eyebrow">
            <span>金融ナレッジベース</span>
            <span>Financial Knowledge Graph</span>
            <span>金融知识库</span>
          </p>
          <h1 id="hero-title">FinWiki</h1>
          <p class="lede-ja">
            公開情報に基づく金融機関、決済、暗号資産、資本市場の知識グラフ。
          </p>
          <p class="lede-en">
            A public-source financial knowledge graph built for trilingual reading, retrieval, citation, and AI traversal.
          </p>
          <p class="lede-zh">
            面向人和 AI 的公开金融知识库，连接日本金融机构、支付、加密资产与资本市场。
          </p>
          <div class="hero-actions" aria-label="Primary entrances">
            <a class="primary-action" href="/ja/">日本語で読む</a>
            <a href="/en/">Read in English</a>
            <a href="/zh/">中文阅读</a>
          </div>
        </div>
      </section>

      <section class="quick" aria-labelledby="quick-title">
        <div class="section-head">
          <p class="kicker">Start</p>
          <h2 id="quick-title">Choose an entrance</h2>
        </div>
        <div class="language-grid">
          <a class="language-tile" href="/ja/">
            <span class="tile-label">日本語</span>
            <strong>領域マップから読む</strong>
            <span>日本語原文を中心に、主要条目へ直接入れます。</span>
          </a>
          <a class="language-tile" href="/en/">
            <span class="tile-label">English</span>
            <strong>Browse the public graph</strong>
            <span>Open the English surface where verified translations exist.</span>
          </a>
          <a class="language-tile" href="/zh/">
            <span class="tile-label">简体中文</span>
            <strong>进入中文目录</strong>
            <span>查看已通过占位符校验的中文译文与回退原文。</span>
          </a>
        </div>
      </section>

      <section class="coverage" aria-labelledby="coverage-title">
        <div class="section-head">
          <p class="kicker">Coverage</p>
          <h2 id="coverage-title">Public finance corpus</h2>
        </div>
        <div class="stats" aria-label="Current site statistics">
          <div class="metric">
            <strong>{entryCount.toLocaleString('en-US')}</strong>
            <span>human entries</span>
          </div>
          <div class="metric">
            <strong>{domainCount}</strong>
            <span>domains</span>
          </div>
          <div class="metric">
            <strong>{zhCount.toLocaleString('en-US')}</strong>
            <span>zh translations</span>
          </div>
          <div class="metric">
            <strong>{enCount.toLocaleString('en-US')}</strong>
            <span>en translations</span>
          </div>
        </div>

        <div class="domain-strip" aria-label="Featured domains">
          {featuredDomains.map(({ domain, count }) => (
            <a href={`/ja/browse/#${domain}`}>
              <span>{domainName(domain, 'ja')}</span>
              <strong>{count}</strong>
            </a>
          ))}
        </div>
      </section>

      <section class="surfaces" aria-labelledby="surfaces-title">
        <div class="section-head">
          <p class="kicker">Machine-readable</p>
          <h2 id="surfaces-title">AI discovery surface</h2>
        </div>
        <div class="surface-links">
          <a href="/llms.txt">
            <span>llms.txt</span>
            <strong>short crawler guide</strong>
          </a>
          <a href="/llms-full.txt">
            <span>llms-full.txt</span>
            <strong>full page manifest</strong>
          </a>
          <a href="/ai-index.json">
            <span>ai-index.json</span>
            <strong>structured retrieval map</strong>
          </a>
          <a href="/sitemap.xml">
            <span>sitemap.xml</span>
            <strong>public URL inventory</strong>
          </a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <span>FinWiki</span>
      <span>Public sources only. Human pages and AI surfaces are published from the same knowledge graph.</span>
    </footer>
  </body>
</html>

<style>
  :root {
    --ink: #071817;
    --ink-soft: #102624;
    --paper: #fbfaf5;
    --muted: #66716f;
    --line: #d9ded8;
    --aqua: #62f0e8;
    --gold: #f2b84b;
    --leaf: #77b885;
    --coral: #e4665c;
    --max: 1180px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    color-scheme: light;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Hiragino Sans", "Noto Sans CJK JP", "Noto Sans SC", sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
  }

  a {
    color: inherit;
  }

  .topbar {
    position: absolute;
    inset: 0 0 auto;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    max-width: var(--max);
    margin: 0 auto;
    padding: 1.1rem clamp(1rem, 4vw, 2rem);
    color: white;
  }

  .brand {
    font-size: 1.05rem;
    font-weight: 800;
    text-decoration: none;
  }

  .topnav {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .topnav a {
    min-height: 2.25rem;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgb(255 255 255 / 0.22);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    text-decoration: none;
    font-size: 0.86rem;
    color: rgb(255 255 255 / 0.86);
    background: rgb(7 24 23 / 0.25);
  }

  .topnav a:hover,
  .topnav a:focus-visible {
    color: white;
    border-color: var(--aqua);
    outline: none;
  }

  .hero {
    position: relative;
    isolation: isolate;
    min-height: 76svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--ink);
    color: white;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    opacity: 0.34;
    background: url("/og-image.png") right center / auto 100% no-repeat;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, rgb(7 24 23 / 0.98) 0%, rgb(7 24 23 / 0.9) 50%, rgb(7 24 23 / 0.58) 100%),
      linear-gradient(180deg, transparent 64%, rgb(7 24 23 / 0.8));
  }

  .hero-copy {
    width: 100%;
    max-width: var(--max);
    margin: 0 auto;
    padding: clamp(6.8rem, 14vh, 10rem) clamp(1rem, 4vw, 2rem) clamp(3.8rem, 9vh, 6rem);
  }

  .eyebrow,
  .kicker {
    margin: 0 0 0.8rem;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--aqua);
    overflow-wrap: anywhere;
    word-break: normal;
  }

  .eyebrow {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .eyebrow span:not(:last-child)::after {
    content: "/";
    margin-left: 0.35rem;
  }

  h1 {
    margin: 0 0 0.6rem;
    font-size: clamp(3.4rem, 11vw, 8.4rem);
    line-height: 0.9;
  }

  .lede-ja,
  .lede-en,
  .lede-zh {
    max-width: 46rem;
    margin: 0.45rem 0 0;
    color: rgb(255 255 255 / 0.88);
    overflow-wrap: anywhere;
    word-break: normal;
  }

  .lede-ja {
    font-size: clamp(1.15rem, 2vw, 1.65rem);
    font-weight: 700;
    color: white;
  }

  .lede-en,
  .lede-zh {
    font-size: clamp(0.98rem, 1.4vw, 1.15rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.9rem;
  }

  .hero-actions a {
    min-height: 2.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(255 255 255 / 0.26);
    border-radius: 999px;
    padding: 0.65rem 1rem;
    text-decoration: none;
    color: white;
    background: rgb(255 255 255 / 0.08);
    font-weight: 700;
  }

  .hero-actions .primary-action {
    color: var(--ink);
    background: var(--aqua);
    border-color: var(--aqua);
  }

  .hero-actions a:hover,
  .hero-actions a:focus-visible {
    transform: translateY(-1px);
    outline: none;
    border-color: var(--gold);
  }

  .quick,
  .coverage,
  .surfaces {
    width: 100%;
    max-width: var(--max);
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1rem, 4vw, 2rem);
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .section-head h2 {
    margin: 0;
    font-size: clamp(1.45rem, 2.4vw, 2.1rem);
    line-height: 1.15;
  }

  .kicker {
    color: var(--coral);
  }

  .language-grid,
  .stats,
  .surface-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .language-tile,
  .metric,
  .surface-links a,
  .domain-strip a {
    border: 1px solid var(--line);
    background: white;
    border-radius: 8px;
  }

  .language-tile {
    min-height: 11rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1rem;
    text-decoration: none;
  }

  .language-tile:hover,
  .language-tile:focus-visible,
  .surface-links a:hover,
  .surface-links a:focus-visible,
  .domain-strip a:hover,
  .domain-strip a:focus-visible {
    border-color: var(--ink);
    outline: none;
  }

  .tile-label {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .language-tile strong {
    margin: 0.9rem 0 0.35rem;
    font-size: 1.1rem;
  }

  .language-tile span:last-child {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .coverage {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .stats {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .metric {
    min-height: 7rem;
    padding: 1rem;
  }

  .metric strong {
    display: block;
    color: var(--ink-soft);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
  }

  .metric span {
    display: block;
    margin-top: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .domain-strip {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .domain-strip a {
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.8rem;
    text-decoration: none;
    font-size: 0.92rem;
  }

  .domain-strip strong {
    color: var(--coral);
  }

  .surface-links {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .surface-links a {
    min-height: 6.2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1rem;
    text-decoration: none;
  }

  .surface-links span {
    color: var(--muted);
    font-size: 0.86rem;
  }

  .surface-links strong {
    font-size: 1rem;
  }

  .footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    max-width: var(--max);
    margin: 0 auto;
    padding: 1.6rem clamp(1rem, 4vw, 2rem) 2.2rem;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .footer span:first-child {
    color: var(--ink);
    font-weight: 800;
  }

  @media (max-width: 820px) {
    .topbar {
      align-items: flex-start;
    }

    .hero {
      min-height: 78svh;
    }

    .language-grid,
    .stats,
    .surface-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 560px) {
    .topbar {
      position: absolute;
      display: block;
    }

    .topnav {
      justify-content: flex-start;
      margin-top: 0.8rem;
    }

    .hero-copy {
      padding-top: 8.8rem;
    }

    .lede-ja,
    .lede-en,
    .lede-zh {
      max-width: calc(100vw - 2rem);
    }

    .hero::before {
      opacity: 0.22;
      background-position: center;
      background-size: auto 82%;
    }

    .hero-actions a {
      width: 100%;
    }

    .language-grid,
    .stats,
    .surface-links {
      grid-template-columns: 1fr;
    }

    .language-tile,
    .metric,
    .surface-links a {
      min-height: auto;
    }

    .footer {
      display: block;
    }

    .footer span {
      display: block;
      margin-top: 0.35rem;
    }
  }
</style>
