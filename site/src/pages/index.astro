---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { getCollection } from 'astro:content';
import { domainName } from '../i18n/domains';
import { entryDomain } from '../lib/routes';

const entries = await getCollection('entries');
const translations = await getCollection('i18n');

const counts = new Map<string, number>();
for (const entry of entries) {
  counts.set(entryDomain(entry), (counts.get(entryDomain(entry)) ?? 0) + 1);
}
const featured = [...counts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);

const entryCount = entries.length;
const domainCount = counts.size;
const zhCount = translations.filter((entry) => entry.id.startsWith('zh/')).length;
const enCount = translations.filter((entry) => entry.id.startsWith('en/')).length;

const updatedAt = new Intl.DateTimeFormat('ja-JP', {
  timeZone: 'Asia/Tokyo',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date());

const entrances = [
  { href: '/ja/', code: '日本語', label: '日本語版', note: '公開一次情報にもとづく日本語版。' },
  { href: '/en/', code: 'English', label: '英語版', note: '英語訳で読む。未整備項目は日本語版へ戻ります。' },
  { href: '/zh/', code: '简体中文', label: '簡体中文版', note: '簡体字中国語訳で読む。未整備項目は日本語版へ戻ります。' },
];
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>FinWiki — 公開金融ナレッジグラフ</title>
    <meta
      name="description"
      content="FinWiki は公開一次情報にもとづき、日本と世界の金融機関・制度・市場構造を三言語で整理する金融ナレッジグラフです。"
    />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('finwiki-theme');
          if (t === 'dark' || t === 'light') document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <link rel="alternate" hreflang="ja" href="/ja/" />
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="alternate" hreflang="zh" href="/zh/" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <meta property="og:title" content="FinWiki" />
    <meta property="og:description" content="公開一次情報にもとづく三言語の金融ナレッジグラフ。" />
    <meta property="og:image" content="/og-image.png" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/" aria-label="FinWiki"><span>Fin<b>Wiki</b></span></a>
        <div style="margin-left:auto"><ThemeToggle lang="ja" /></div>
      </div>
    </header>

    <main class="site-main">
      <section class="root-hero container">
        <p class="eyebrow">公開金融ナレッジグラフ</p>
        <h1 class="root-title">FinWiki</h1>
        <div class="root-taglines">
          <p><span class="rt">JA</span>公開一次情報にもとづく、三言語・出典つきの金融事実ベース。</p>
          <p><span class="rt">EN</span>A trilingual, source-backed financial fact base built on public primary information.</p>
          <p><span class="rt">ZH</span>基于公开一手信源的三语、带出处金融事实库。</p>
        </div>
        <div class="root-stats">
          <span><b>{entryCount.toLocaleString('ja-JP')}</b> 項目</span>
          <span><b>{domainCount}</b> 領域</span>
          <span><b>{zhCount.toLocaleString('en-US')}</b> 中文</span>
          <span><b>{enCount.toLocaleString('en-US')}</b> 英語</span>
        </div>
      </section>

      <section class="container root-block">
        <div class="entrances">
          {entrances.map((e) => (
            <a class="card entrance" href={e.href}>
              <span class="entrance__code">{e.code}</span>
              <span class="card__title">{e.label}</span>
              <span class="muted entrance__note">{e.note}</span>
              <span class="entrance__go">→</span>
            </a>
          ))}
        </div>
      </section>

      <section class="container root-block">
        <p class="eyebrow">収録領域</p>
        <h2 class="section-title">主要領域</h2>
        <div class="root-domains">
          {featured.map(([d, n]) => (
            <a class="card root-dcard" href={`/ja/domains/${d}/`}>
              <span class="root-dcard__ja">{domainName(d, 'ja')}</span>
              <span class="muted root-dcard__meta">{n.toLocaleString('ja-JP')} 項目</span>
              <b class="root-dcard__n">{n.toLocaleString('en-US')}</b>
            </a>
          ))}
        </div>
      </section>

      <section class="container root-block">
        <div class="root-ai">
          <div>
            <p class="eyebrow">機械可読</p>
            <h2 class="section-title">AI・クローラー向け資料</h2>
          </div>
          <div class="root-ai__links">
            <a href="/llms.txt">llms.txt</a>
            <a href="/llms-full.txt">llms-full.txt</a>
            <a href="/ai-index.json">ai-index.json</a>
            <a href="/sitemap.xml">sitemap.xml</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div>
          <div class="site-footer__brand">Fin<span style="color:var(--accent)">Wiki</span></div>
          <p class="site-footer__note">公開一次情報にもとづく金融ナレッジベース。事実は各項目の出典に遡れます。</p>
        </div>
        <nav class="site-footer__links" aria-label="フッター">
          <a href="/ja/">日本語</a>
          <a href="/en/">English</a>
          <a href="/zh/">简体中文</a>
          <a href="/llms.txt">llms.txt</a>
        </nav>
        <div class="site-footer__meta">
          <span>© FinWiki</span>
          <span>最終公開スナップショット: {updatedAt} JST</span>
        </div>
      </div>
    </footer>

    <style>
      .root-hero {
        padding-top: clamp(3rem, 2rem + 5vw, 6rem);
        padding-bottom: var(--sp-5);
      }
      .root-title {
        font-size: var(--fs-3xl);
        line-height: 0.95;
        margin: 0 0 1.4rem;
        letter-spacing: 0;
      }
      .root-taglines {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        max-width: 50rem;
      }
      .root-taglines p {
        margin: 0;
        color: var(--ink-2);
        font-size: var(--fs-md);
        line-height: 1.5;
      }
      .root-taglines p:first-child {
        color: var(--ink);
        font-weight: 550;
      }
      .rt {
        display: inline-block;
        width: 2.2rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--accent);
        letter-spacing: 0.05em;
      }
      .root-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 1.75rem;
        margin-top: 1.8rem;
        color: var(--muted);
        font-size: var(--fs-sm);
      }
      .root-stats b {
        font-family: var(--font-display);
        font-size: 1.6rem;
        color: var(--accent);
        margin-right: 0.35rem;
      }

      .root-block {
        padding-top: var(--gap-section);
      }
      .entrances {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }
      .entrance {
        position: relative;
        min-height: 9rem;
        padding: 1.25rem 1.4rem;
      }
      .entrance__code {
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        font-weight: 700;
        color: var(--accent);
        letter-spacing: 0.04em;
      }
      .entrance__note {
        font-size: var(--fs-sm);
      }
      .entrance__go {
        position: absolute;
        right: 1.2rem;
        bottom: 1rem;
        color: var(--accent);
        font-size: 1.3rem;
        transition: transform var(--dur) var(--ease);
      }
      .entrance:hover .entrance__go {
        transform: translateX(4px);
      }

      .root-domains {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
        gap: 0.85rem;
      }
      .root-dcard {
        position: relative;
        gap: 0.15rem;
        padding: 1rem 1.1rem 1.4rem;
        overflow: hidden;
      }
      .root-dcard__ja {
        font-family: var(--font-display);
        font-weight: 600;
        font-size: var(--fs-base);
      }
      .root-dcard__meta {
        font-size: var(--fs-xs);
      }
      .root-dcard__n {
        position: absolute;
        right: 1rem;
        bottom: 0.7rem;
        font-family: var(--font-display);
        font-size: 1.7rem;
        color: color-mix(in srgb, var(--accent) 22%, transparent);
        font-weight: 600;
      }

      .root-ai {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1.25rem;
        background: var(--surface-2);
        border: 1px solid var(--line);
        border-radius: var(--r-lg);
        padding: clamp(1.5rem, 1rem + 2vw, 2.25rem);
      }
      .root-ai .section-title {
        margin: 0;
      }
      .root-ai__links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }
      .root-ai__links a {
        font-family: var(--font-mono);
        font-size: var(--fs-sm);
        text-decoration: none;
        color: var(--accent-2);
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--r);
        padding: 0.5rem 0.8rem;
      }
      .root-ai__links a:hover {
        border-color: var(--accent);
      }

      @media (max-width: 720px) {
        .entrances {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
