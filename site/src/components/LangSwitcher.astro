---
import { languages, type Lang, restOf, t, u } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const rest = restOf(Astro.url.pathname);
const short: Record<Lang, string> = { ja: '日', en: 'EN', zh: '中' };
---
<div class="lang-switch" role="group" aria-label={t(lang, 'aria.language')}>
  {Object.entries(languages).map(([code]) => (
    <a
      class:list={['', { active: code === lang }]}
      href={u(code as Lang, rest)}
      hreflang={code}
      aria-current={code === lang ? 'true' : undefined}
      title={languages[code as Lang]}
    >{short[code as Lang]}</a>
  ))}
</div>
