---
import '../styles/global.css';
import LangSwitcher from '../components/LangSwitcher.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { t, u, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  active?: 'home' | 'domains' | 'browse' | null;
  wide?: boolean;
}
const { lang, title, description, active = null, wide = false } = Astro.props;
const pageTitle = title ? `${title} · FinWiki` : t(lang, 'site.title');
const desc = description ?? t(lang, 'site.tagline');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('finwiki-theme');
          if (t === 'dark' || t === 'light') document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-component-ui.js" type="module"></script>
    <link rel="alternate" hreflang="ja" href={u('ja')} />
    <link rel="alternate" hreflang="en" href={u('en')} />
    <link rel="alternate" hreflang="zh" href={u('zh')} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content="/og-image.png" />
  </head>
  <body>
    <pagefind-config lang={lang}></pagefind-config>
    <a class="skip-link" href="#main">{t(lang, 'skip.content')}</a>
    <header class="site-header" data-pagefind-ignore>
      <div class="site-header__inner">
        <a class="brand" href={u(lang)} aria-label={t(lang, 'aria.home')}>
          <span>Fin<b>Wiki</b></span>
        </a>
        <nav class="site-nav" aria-label={t(lang, 'aria.primary')}>
          <a href={u(lang, 'domains/')} aria-current={active === 'domains' ? 'page' : undefined}>{t(lang, 'nav.domains')}</a>
          <a href={u(lang, 'browse/')} aria-current={active === 'browse' ? 'page' : undefined}>{t(lang, 'nav.browse')}</a>
          <a href="/llms.txt">{t(lang, 'nav.ai')}</a>
        </nav>
        <div class="header-tools">
          <pagefind-modal-trigger class="pf-trigger" placeholder={t(lang, 'nav.search')} shortcut="mod+k"></pagefind-modal-trigger>
          <ThemeToggle lang={lang} />
          <LangSwitcher lang={lang} />
        </div>
      </div>
    </header>

    <main id="main" class={`site-main${wide ? ' is-wide' : ''}`} data-pagefind-body><slot /></main>

    <pagefind-modal reset-on-close></pagefind-modal>

    <footer class="site-footer" data-pagefind-ignore>
      <div class="site-footer__inner">
        <div>
          <div class="site-footer__brand">Fin<span style="color:var(--accent)">Wiki</span></div>
          <p class="site-footer__note">{t(lang, 'footer.note')}</p>
        </div>
        <nav class="site-footer__links" aria-label={t(lang, 'aria.footer')}>
          <a href={u(lang, 'domains/')}>{t(lang, 'nav.domains')}</a>
          <a href={u(lang, 'browse/')}>{t(lang, 'nav.browse')}</a>
          <a href="/llms.txt">{t(lang, 'footer.llms')}</a>
          <a href="/ai-index.json">{t(lang, 'footer.aiIndex')}</a>
          <a href="/sitemap.xml">{t(lang, 'footer.sitemap')}</a>
        </nav>
        <div class="site-footer__meta">
          <span>© FinWiki</span>
          <span>{t(lang, 'footer.langs')}</span>
        </div>
      </div>
    </footer>

    <style>
      .pf-trigger {
        display: inline-flex;
        font-size: var(--fs-sm);
      }
      @media (max-width: 560px) {
        .site-header__inner {
          gap: 0.55rem;
          padding-inline: 0.75rem;
          overflow: hidden;
        }
        .brand {
          flex: 0 0 auto;
        }
        .site-nav {
          flex: 1 1 auto;
          gap: 0.55rem;
          margin-right: 0;
          min-width: 0;
          overflow: hidden;
        }
        .site-nav a {
          font-size: var(--fs-xs);
          overflow: hidden;
          text-overflow: ellipsis;
        }
        .site-nav a:nth-child(3) {
          display: none;
        }
        .header-tools {
          gap: 0.35rem;
          flex: 0 0 auto;
          margin-left: auto;
        }
        .pf-trigger {
          display: none;
        }
        .brand small {
          display: none;
        }
      }
      @media (max-width: 380px) {
        .site-nav a:nth-child(2) {
          display: none;
        }
      }
    </style>
  </body>
</html>
