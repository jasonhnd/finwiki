---
import '../styles/global.css';
import LangSwitcher from '../components/LangSwitcher.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { t, u, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  active?: 'home' | 'domains' | 'browse' | 'ai' | null;
  wide?: boolean;
}
const { lang, title, description, active = null, wide = false } = Astro.props;
const pageTitle = title ? `${title} · FinWiki` : t(lang, 'site.title');
const desc = description ?? t(lang, 'site.tagline');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('finwiki-theme');
          if (t === 'dark' || t === 'light') document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <link rel="preload" href="/fonts/source-serif-4/source-serif-4-latin-600.woff2" as="font" type="font/woff2" crossorigin />
    <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-component-ui.js" type="module"></script>
    <link rel="alternate" hreflang="ja" href={u('ja')} />
    <link rel="alternate" hreflang="en" href={u('en')} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content="/og-image.png" />
  </head>
  <body>
    <pagefind-config lang={lang}></pagefind-config>
    <a class="skip-link" href="#main">{t(lang, 'skip.content')}</a>
    <header class="site-header" data-pagefind-ignore>
      <div class="site-header__inner">
        <a class="brand" href={u(lang)} aria-label={t(lang, 'aria.home')}>
          <span>Fin<b>Wiki</b></span>
          <small>{t(lang, 'site.subtitle')}</small>
        </a>
        <nav class="site-nav" aria-label={t(lang, 'aria.primary')}>
          <a href={u(lang)} aria-current={active === 'home' ? 'page' : undefined}>{t(lang, 'nav.home')}</a>
          <a href={u(lang, 'domains/')} aria-current={active === 'domains' ? 'page' : undefined}>{t(lang, 'nav.domains')}</a>
          <a href={u(lang, 'browse/')} aria-current={active === 'browse' ? 'page' : undefined}>{t(lang, 'nav.browse')}</a>
          <a href="/llms.txt" aria-current={active === 'ai' ? 'page' : undefined}>{t(lang, 'nav.ai')}</a>
        </nav>
        <div class="header-tools">
          <pagefind-modal-trigger class="pf-trigger" placeholder={t(lang, 'nav.search')} shortcut="mod+k"></pagefind-modal-trigger>
          <ThemeToggle lang={lang} />
          <LangSwitcher lang={lang} />
        </div>
      </div>
    </header>

    <main id="main" class={`site-main${wide ? ' is-wide' : ''}`} data-pagefind-body><slot /></main>

    <div id="wl-preview" class="wl-preview" role="tooltip" aria-hidden="true" aria-label={t(lang, 'wikilink.preview')} data-pagefind-ignore>
      <div class="wl-preview__title"></div>
      <div class="wl-preview__lead"></div>
      <div class="wl-preview__meta"></div>
    </div>

    <pagefind-modal reset-on-close></pagefind-modal>

    <footer class="site-footer" data-pagefind-ignore>
      <div class="site-footer__inner">
        <div class="site-footer__about">
          <div class="site-footer__brand">Fin<span style="color:var(--accent)">Wiki</span></div>
          <p class="site-footer__note">{t(lang, 'footer.note')}</p>
        </div>
        <nav class="site-footer__links" aria-label={t(lang, 'aria.footer')}>
          <a href={u(lang)}>{t(lang, 'nav.home')}</a>
          <a href={u(lang, 'domains/')}>{t(lang, 'nav.domains')}</a>
          <a href={u(lang, 'browse/')}>{t(lang, 'nav.browse')}</a>
          <a href="/llms.txt">{t(lang, 'footer.llms')}</a>
          <a href="/ai-index.json">{t(lang, 'footer.aiIndex')}</a>
          <a href="/sitemap.xml">{t(lang, 'footer.sitemap')}</a>
        </nav>
        <div class="site-footer__meta">
          <span>© FinWiki</span>
          <span>{t(lang, 'footer.langs')}</span>
        </div>
      </div>
    </footer>

    <style>
      .pf-trigger {
        display: inline-flex;
        font-size: var(--fs-sm);
      }
      @media (max-width: 560px) {
        .site-nav {
          gap: 0.75rem;
        }
      }
    </style>
    <script>
      (() => {
        const pointerQuery = window.matchMedia('(hover: none), (pointer: coarse)');
        if (pointerQuery.matches) return;

        const preview = document.getElementById('wl-preview');
        const links = Array.from(document.querySelectorAll('.prose a.wl[data-wl-kind][data-wl-route]'));
        if (!preview || !links.length) return;

        const lang = document.documentElement.lang === 'en' ? 'en' : 'ja';
        const titleEl = preview.querySelector('.wl-preview__title');
        const leadEl = preview.querySelector('.wl-preview__lead');
        const metaEl = preview.querySelector('.wl-preview__meta');
        if (!titleEl || !leadEl || !metaEl) return;

        const previewMap = new Map();
        for (const link of links) {
          const kind = link.getAttribute('data-wl-kind') || 'route';
          const route = link.getAttribute('data-wl-route') || link.getAttribute('data-wl') || '';
          const title = link.getAttribute(`data-wl-title-${lang}`) || link.getAttribute('data-wl-title-ja') || '';
          const lead = link.getAttribute(`data-wl-lead-${lang}`) || link.getAttribute('data-wl-lead-ja') || '';
          const domain = link.getAttribute(`data-wl-domain-${lang}`) || link.getAttribute('data-wl-domain-ja') || '';
          if (kind === 'route' || kind === 'peer' || kind === 'system') link.classList.add(`wl--${kind}`);
          if (route && title && lead && !previewMap.has(route)) {
            previewMap.set(route, { title, lead, domain, route });
          }
        }

        let activeLink = null;
        let timer = 0;

        function clearTimer() {
          if (timer) {
            window.clearTimeout(timer);
            timer = 0;
          }
        }

        function place(link) {
          const rect = link.getBoundingClientRect();
          const box = preview.getBoundingClientRect();
          const margin = 12;
          let top = rect.bottom + 10;
          if (top + box.height + margin > window.innerHeight) top = rect.top - box.height - 10;
          if (top < margin) top = margin;

          let left = rect.left + rect.width / 2 - box.width / 2;
          left = Math.max(margin, Math.min(left, window.innerWidth - box.width - margin));
          preview.style.left = `${Math.round(left)}px`;
          preview.style.top = `${Math.round(top)}px`;
        }

        function closePreview() {
          clearTimer();
          if (activeLink) activeLink.removeAttribute('aria-describedby');
          activeLink = null;
          preview.classList.remove('is-visible');
          preview.setAttribute('aria-hidden', 'true');
        }

        function openPreview(link) {
          const route = link.getAttribute('data-wl-route') || link.getAttribute('data-wl') || '';
          const item = previewMap.get(route);
          if (!item) return;

          activeLink?.removeAttribute('aria-describedby');
          activeLink = link;
          titleEl.textContent = item.title;
          leadEl.textContent = item.lead;
          metaEl.textContent = [item.domain, item.route].filter(Boolean).join(' / ');
          preview.setAttribute('aria-hidden', 'false');
          preview.classList.add('is-visible');
          link.setAttribute('aria-describedby', 'wl-preview');
          requestAnimationFrame(() => {
            if (activeLink === link) place(link);
          });
        }

        function schedulePreview(link) {
          clearTimer();
          timer = window.setTimeout(() => openPreview(link), 220);
        }

        for (const link of links) {
          if (!previewMap.has(link.getAttribute('data-wl-route') || link.getAttribute('data-wl') || '')) continue;
          link.addEventListener('pointerenter', (event) => {
            if (event.pointerType === 'touch') return;
            schedulePreview(link);
          });
          link.addEventListener('pointerleave', closePreview);
          link.addEventListener('focus', () => schedulePreview(link));
          link.addEventListener('blur', closePreview);
        }

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') closePreview();
        });
        window.addEventListener('scroll', closePreview, { passive: true, capture: true });
        window.addEventListener('resize', closePreview, { passive: true });
        pointerQuery.addEventListener?.('change', (event) => {
          if (event.matches) closePreview();
        });
      })();
    </script>
  </body>
</html>
