---
import Base from './Base.astro';
import { t, u, type Lang } from '../i18n/ui';
import { domainName } from '../i18n/domains';
import { domainGroups, groupName } from '../i18n/groups';
import { entryDomain, entryRoute } from '../lib/routes';

interface DomainCount { slug: string; count: number }
interface Heading { depth: number; slug: string; text: string }
interface Props {
  lang: Lang;
  entry: any;
  tr?: any;
  headings?: Heading[];
  domains?: DomainCount[];
}
const { lang, entry, tr, headings = [], domains = [] } = Astro.props;

const fm = entry.data ?? {};
const route = entryRoute(entry);
const domain = entryDomain(entry);
const sources = Array.isArray(fm.sources) ? fm.sources : [];
const updated = fm.last_updated ? String(fm.last_updated).slice(0, 10) : null;
const reviewBy = fm.review_by ? String(fm.review_by).slice(0, 10) : null;
const confidence = fm.confidence ? String(fm.confidence) : null;
const tags = Array.isArray(fm.tags) ? fm.tags.slice(0, 6) : [];
const title = (tr?.data?.title && String(tr.data.title)) || fm.title;
const machine = !!tr && tr.data?.status === 'machine';
const needsReview = tr?.data?.fidelity === 'needs_review';
const origHref = lang !== 'ja' ? u('ja', `${route}/`) : null;

const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const hasSourcesAnchor = headings.some((h) => h.slug === 'sources');

const counts = new Map(domains.map((d) => [d.slug, d.count]));
const confTone =
  confidence && /confirm|high/i.test(confidence)
    ? 'ok'
    : confidence && /likely|medium|moderate/i.test(confidence)
      ? 'accent'
      : confidence
        ? 'warn'
        : 'muted';
const overdue = reviewBy ? reviewBy < '2026-06-02' : false;
---
<Base lang={lang} title={title} wide>
  <div class="doc">
    <aside class="drail drail--left" data-pagefind-ignore>
      <nav aria-label={t(lang, 'nav.domains')}>
        <p class="drail__label">{t(lang, 'nav.domains')}</p>
        {domainGroups.map((g) => {
          const ds = g.domains.filter((d) => counts.has(d));
          if (!ds.length) return null;
          return (
            <div class="drail__group">
              <span class="drail__gname">{groupName(g, lang)}</span>
              <ul>
                {ds.map((d) => (
                  <li>
                    <a href={u(lang, `domains/${d}/`)} class:list={['drail__d', { cur: d === domain }]}>
                      <span>{domainName(d, lang)}</span>
                      <b>{counts.get(d)}</b>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </nav>
    </aside>

    <article class="doc-article">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={u(lang, 'domains/')}>{t(lang, 'nav.domains')}</a>
        <span aria-hidden="true">/</span>
        <a href={u(lang, `domains/${domain}/`)}>{domainName(domain, lang)}</a>
      </nav>

      <header class="entry-head">
        <h1>{title}</h1>
        <div class="factbar">
          {confidence && (
            <span class={`chip chip--${confTone === 'accent' ? 'accent' : confTone === 'warn' ? 'warn' : ''}`.trim()}>
              <span class="dot" style={`color:var(--${confTone === 'muted' ? 'muted' : confTone})`}></span>
              {t(lang, 'entry.confidence')}: {confidence}
            </span>
          )}
          {updated && <span class="chip">{t(lang, 'entry.updated')} {updated}</span>}
          {reviewBy && (
            <span class={`chip${overdue ? ' chip--warn' : ''}`}>{t(lang, 'entry.reviewBy')} {reviewBy}</span>
          )}
          {sources.length > 0 && (
            hasSourcesAnchor ? (
              <a class="chip chip--accent" href="#sources">{t(lang, 'entry.sources')} {sources.length}</a>
            ) : (
              <span class="chip">{t(lang, 'entry.sources')} {sources.length}</span>
            )
          )}
          {machine && (
            <span class="chip chip--warn">{t(lang, 'entry.machine')}{needsReview ? ` · ${t(lang, 'entry.needsReview')}` : ''}</span>
          )}
          {origHref && <a class="chip chip--accent" href={origHref}>{t(lang, 'entry.original')}</a>}
        </div>
        {tags.length > 0 && (
          <div class="tagrow">
            {tags.map((tag: string) => <span class="tag">#{tag}</span>)}
          </div>
        )}
      </header>

      {toc.length > 2 && (
        <details class="toc-inline" data-pagefind-ignore>
          <summary>{t(lang, 'entry.onThisPage')}</summary>
          <ul>
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'lv3' : ''}><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ul>
        </details>
      )}

      <div class="prose"><slot /></div>
    </article>

    <aside class="drail drail--right" data-pagefind-ignore>
      {toc.length > 0 && (
        <nav class="toc toc--rail" aria-label={t(lang, 'entry.onThisPage')}>
          <p class="toc__label">{t(lang, 'entry.onThisPage')}</p>
          <ul>
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'lv3' : ''}><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ul>
        </nav>
      )}
    </aside>
  </div>
</Base>

<style>
  .doc {
    display: grid;
    grid-template-columns: 14rem minmax(0, 48rem) 13rem;
    justify-content: center;
    gap: clamp(1.5rem, 1rem + 2.2vw, 3.25rem);
    max-width: var(--w-wide);
    margin-inline: auto;
    padding: var(--sp-6) clamp(1rem, 0.4rem + 2.5vw, 2rem) var(--sp-8);
    align-items: start;
  }
  .drail {
    position: sticky;
    top: calc(var(--header-h) + 1.25rem);
    max-height: calc(100vh - var(--header-h) - 2.5rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    font-size: var(--fs-sm);
    scrollbar-width: thin;
  }

  /* left domain rail */
  .drail__label,
  .toc__label {
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.7rem;
  }
  .drail__group {
    margin-bottom: 1rem;
  }
  .drail__gname {
    display: block;
    font-size: var(--fs-xs);
    font-weight: 700;
    color: var(--ink-2);
    margin-bottom: 0.25rem;
  }
  .drail ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .drail__d {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    align-items: baseline;
    padding: 0.2rem 0.5rem;
    margin-left: -0.5rem;
    border-radius: var(--r-sm);
    text-decoration: none;
    color: var(--ink-2);
    border-left: 2px solid transparent;
  }
  .drail__d:hover {
    background: var(--surface-2);
    color: var(--ink);
  }
  .drail__d.cur {
    color: var(--accent-2);
    font-weight: 650;
    background: var(--accent-soft);
    border-left-color: var(--accent);
  }
  .drail__d b {
    font-weight: 500;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  /* article */
  .doc-article {
    min-width: 0;
  }
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    font-size: var(--fs-sm);
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .crumbs a {
    color: var(--accent-2);
    text-decoration: none;
  }
  .crumbs a:hover {
    text-decoration: underline;
  }
  .entry-head {
    margin-bottom: 1.6rem;
    padding-bottom: 1.3rem;
    border-bottom: 1px solid var(--line);
  }
  .entry-head h1 {
    font-size: var(--fs-2xl);
    line-height: 1.15;
    margin: 0 0 0.9rem;
  }
  .factbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }
  .tagrow {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.7rem;
    margin-top: 0.8rem;
  }
  .tag {
    font-size: var(--fs-xs);
    color: var(--muted);
    font-family: var(--font-mono);
  }

  /* right toc */
  .toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--line);
  }
  .toc li {
    margin: 0;
  }
  .toc li.lv3 a {
    padding-left: 1.5rem;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .toc a {
    display: block;
    padding: 0.22rem 0 0.22rem 0.85rem;
    margin-left: -1px;
    border-left: 2px solid transparent;
    text-decoration: none;
    color: var(--ink-2);
    line-height: 1.35;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .toc a:hover {
    color: var(--ink);
  }
  .toc a.active {
    color: var(--accent-2);
    border-left-color: var(--accent);
    font-weight: 600;
  }

  /* inline (mobile) toc */
  .toc-inline {
    display: none;
    margin: 0 0 1.6rem;
    border: 1px solid var(--line);
    border-radius: var(--r);
    background: var(--surface-2);
    padding: 0.5rem 0.9rem;
  }
  .toc-inline summary {
    cursor: pointer;
    font-weight: 650;
    font-size: var(--fs-sm);
    color: var(--ink-2);
  }
  .toc-inline ul {
    list-style: none;
    margin: 0.6rem 0 0.3rem;
    padding: 0;
  }
  .toc-inline li {
    margin: 0.15rem 0;
  }
  .toc-inline li.lv3 {
    padding-left: 1rem;
  }
  .toc-inline a {
    color: var(--ink-2);
    text-decoration: none;
    font-size: var(--fs-sm);
  }

  @media (max-width: 1080px) {
    .doc {
      grid-template-columns: 13rem minmax(0, 1fr);
    }
    .drail--right {
      display: none;
    }
    .toc-inline {
      display: block;
    }
  }
  @media (max-width: 820px) {
    .doc {
      grid-template-columns: minmax(0, 1fr);
      max-width: 46rem;
    }
    .drail--left {
      display: none;
    }
  }
</style>

<script>
  const links = Array.from(document.querySelectorAll('.toc--rail a')) as HTMLAnchorElement[];
  const map = new Map(links.map((a) => [decodeURIComponent((a.getAttribute('href') || '').slice(1)), a]));
  const heads = Array.from(document.querySelectorAll('.prose h2[id], .prose h3[id]'));
  if (heads.length && map.size && 'IntersectionObserver' in window) {
    let active: HTMLAnchorElement | null = null;
    const obs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const a = map.get((e.target as HTMLElement).id);
          if (a && a !== active) {
            active?.classList.remove('active');
            a.classList.add('active');
            active = a;
          }
        }
      },
      { rootMargin: '-78px 0px -68% 0px', threshold: 0 },
    );
    heads.forEach((h) => obs.observe(h));
  }
</script>
