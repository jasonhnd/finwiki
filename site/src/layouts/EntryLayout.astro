---
import Base from './Base.astro';
import { getCollection } from 'astro:content';
import { confidenceLabel, t, u, type Lang } from '../i18n/ui';
import { domainName } from '../i18n/domains';
import { domainGroups, groupName } from '../i18n/groups';
import { entryDomain, entryRoute } from '../lib/routes';
import { isoDate } from '../lib/format';
import { localizedTitle } from '../lib/siteIndex.mjs';
import { buildEntryDiscovery } from '../lib/entryDiscovery.mjs';

interface DomainCount { slug: string; count: number }
interface Heading { depth: number; slug: string; text: string }
interface Props {
  lang: Lang;
  entry: any;
  tr?: any;
  headings?: Heading[];
  domains?: DomainCount[];
}
const { lang, entry, tr, headings = [], domains = [] } = Astro.props;

const fm = entry.data ?? {};
const route = entryRoute(entry);
const domain = entryDomain(entry);
const sources = Array.isArray(fm.sources) ? fm.sources : [];
const updated = isoDate(fm.last_updated) || null;
const reviewBy = isoDate(fm.review_by) || null;
const confidence = fm.confidence ? String(fm.confidence) : null;
const tags = Array.isArray(fm.tags) ? fm.tags.slice(0, 6) : [];
const title = (tr?.data?.title && String(tr.data.title)) || localizedTitle(lang, route) || fm.title;
const confidenceText = confidence ? confidenceLabel(lang, confidence) : null;
const machine = !!tr && tr.data?.status === 'machine';
const needsReview = tr?.data?.fidelity === 'needs_review';
const origHref = lang !== 'ja' ? u('ja', `${route}/`) : null;

const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const hasSourcesAnchor = headings.some((h) => h.slug === 'sources');

const counts = new Map(domains.map((d) => [d.slug, d.count]));
const currentGroup = domainGroups.find((g) => g.domains.includes(domain));
const railGroupLabel = currentGroup ? groupName(currentGroup, lang) : domainName(domain, lang);
const railDomainsRaw = currentGroup ? currentGroup.domains.filter((d) => counts.has(d)) : [domain];
const railDomains = railDomainsRaw.includes(domain) ? railDomainsRaw : [domain, ...railDomainsRaw];
const confTone =
  confidence && /confirm|high/i.test(confidence)
    ? 'ok'
    : confidence && /likely|medium|moderate/i.test(confidence)
      ? 'accent'
      : confidence
        ? 'warn'
        : 'muted';
const overdue = reviewBy ? reviewBy < '2026-06-02' : false;
const allEntries = await getCollection('entries');
const discovery = buildEntryDiscovery({ lang, entry, entries: allEntries });
const discoveryLaneLabels = {
  related: t(lang, 'entry.discovery.related'),
  next: t(lang, 'entry.discovery.next'),
  backlinks: t(lang, 'entry.discovery.backlinks'),
};
const discoveryLaneLabel = (id: string) => discoveryLaneLabels[id as keyof typeof discoveryLaneLabels] ?? id;
---
<Base lang={lang} title={title} active="domains" wide>
  <div class="doc">
    <aside class="drail drail--left" data-pagefind-ignore>
      <nav aria-label={t(lang, 'entry.inThisDomain')}>
        <div class="drail__head">
          <p class="drail__label">{t(lang, 'entry.inThisDomain')}</p>
          <a class="drail__all" href={u(lang, 'domains/')}>{t(lang, 'nav.allDomains')}</a>
        </div>
        <div class="drail__group">
          <span class="drail__gname">{railGroupLabel}</span>
          <ul>
            {railDomains.map((d) => (
              <li>
                <a href={u(lang, `domains/${d}/`)} class:list={['drail__d', { cur: d === domain }]}>
                  <span>{domainName(d, lang)}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </aside>

    <article class="doc-article">
      <nav class="crumbs" aria-label={t(lang, 'aria.breadcrumb')}>
        <a href={u(lang, 'domains/')}>{t(lang, 'nav.domains')}</a>
        <span aria-hidden="true">/</span>
        <a href={u(lang, `domains/${domain}/`)}>{domainName(domain, lang)}</a>
      </nav>

      <header class="entry-head">
        <h1>{title}</h1>
        <div class="evidence-strip">
          {confidence && (
            <div class={`evidence-item evidence-item--${confTone}`}>
              <span class="evidence-label">{t(lang, 'entry.confidence')}</span>
              <span class="evidence-value"><span class="dot"></span>{confidenceText}</span>
            </div>
          )}
          {updated && (
            <div class="evidence-item">
              <span class="evidence-label">{t(lang, 'entry.updated')}</span>
              <span class="evidence-value">{updated}</span>
            </div>
          )}
          {reviewBy && (
            <div class:list={['evidence-item', { 'evidence-item--warn': overdue }]}>
              <span class="evidence-label">{t(lang, 'entry.reviewBy')}</span>
              <span class="evidence-value">{reviewBy}</span>
            </div>
          )}
          {sources.length > 0 && (
            hasSourcesAnchor ? (
              <a class="evidence-item evidence-item--source" href="#sources">
                <span class="evidence-label">{t(lang, 'entry.sources')}</span>
                <span class="evidence-value">{sources.length}</span>
              </a>
            ) : (
              <div class="evidence-item">
                <span class="evidence-label">{t(lang, 'entry.sources')}</span>
                <span class="evidence-value">{sources.length}</span>
              </div>
            )
          )}
          {machine && (
            <span class="evidence-badge evidence-badge--warn">{t(lang, 'entry.machine')}{needsReview ? ` · ${t(lang, 'entry.needsReview')}` : ''}</span>
          )}
          {origHref && <a class="evidence-badge evidence-badge--link" href={origHref}>{t(lang, 'entry.original')}</a>}
        </div>
        {tags.length > 0 && (
          <div class="tagrow" aria-label={t(lang, 'entry.tags')}>
            {tags.map((tag: string) => <span class="tag">#{tag}</span>)}
          </div>
        )}
      </header>

      {toc.length > 2 && (
        <details class="toc-inline" data-pagefind-ignore>
          <summary>{t(lang, 'entry.onThisPage')}</summary>
          <ul>
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'lv3' : ''}><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ul>
        </details>
      )}

      <div class="prose"><slot /></div>

      {discovery.lanes.length > 0 && (
        <section class="entry-discovery" aria-labelledby="entry-discovery-title" data-pagefind-ignore>
          <div class="entry-discovery__head">
            <p class="entry-discovery__kicker">{t(lang, 'entry.discovery.kicker')}</p>
            <h2 id="entry-discovery-title">{t(lang, 'entry.discovery')}</h2>
          </div>
          <div class="entry-discovery__lanes">
            {discovery.lanes.map((lane: any) => (
              <section class:list={['entry-discovery__lane', `entry-discovery__lane--${lane.id}`]} aria-label={discoveryLaneLabel(lane.id)}>
                <h3>{discoveryLaneLabel(lane.id)}</h3>
                <ul class="entry-discovery__list">
                  {lane.items.map((item: any) => (
                    <li>
                      <a class="entry-card" href={u(lang, `${item.route}/`)}>
                        <span class="entry-card__meta">{item.domain}</span>
                        <span class="entry-card__title">{item.title}</span>
                        <span class="entry-card__lead">{item.lead}</span>
                        <span class="entry-card__route">{item.route}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </section>
      )}
    </article>

    <aside class="drail drail--right" data-pagefind-ignore>
      {toc.length > 0 && (
        <nav class="toc toc--rail" aria-label={t(lang, 'entry.onThisPage')}>
          <p class="toc__label">{t(lang, 'entry.onThisPage')}</p>
          <ul>
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'lv3' : ''}><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ul>
        </nav>
      )}
    </aside>
  </div>
</Base>

<style>
  .doc {
    display: grid;
    grid-template-columns: var(--rail-left) minmax(0, var(--measure-entry)) var(--rail-right);
    justify-content: center;
    gap: clamp(1.5rem, 1rem + 2.2vw, 3.25rem);
    max-width: var(--w-wide);
    margin-inline: auto;
    padding: var(--sp-6) clamp(1rem, 0.4rem + 2.5vw, 2rem) var(--sp-8);
    align-items: start;
  }
  .drail {
    position: sticky;
    top: calc(var(--header-h) + 1.25rem);
    max-height: calc(100vh - var(--header-h) - 2.5rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    font-size: var(--fs-sm);
    scrollbar-width: thin;
  }

  /* left domain rail */
  .drail__label,
  .toc__label {
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.7rem;
  }
  .drail__head {
    display: grid;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }
  .drail__head .drail__label {
    margin-bottom: 0;
  }
  .drail__all {
    width: max-content;
    color: var(--accent-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent-2) 45%, transparent);
  }
  .drail__all:hover {
    border-bottom-color: var(--accent);
  }
  .drail__group {
    margin-bottom: 1rem;
  }
  .drail__gname {
    display: block;
    font-size: var(--fs-xs);
    font-weight: 700;
    color: var(--ink-2);
    margin-bottom: 0.25rem;
  }
  .drail ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .drail__d {
    display: block;
    padding: 0.24rem 0.55rem;
    margin-left: -0.5rem;
    border-radius: var(--r-sm);
    text-decoration: none;
    color: var(--ink-2);
    border-left: 2px solid transparent;
  }
  .drail__d:hover {
    background: var(--surface-2);
    color: var(--ink);
  }
  .drail__d.cur {
    color: var(--accent-2);
    font-weight: 650;
    background: var(--accent-soft);
    border-left-color: var(--accent);
  }
  .drail__d b {
    font-weight: 500;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  /* article */
  .doc-article {
    min-width: 0;
  }
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    font-size: var(--fs-sm);
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .crumbs a {
    color: var(--accent-2);
    text-decoration: none;
  }
  .crumbs a:hover {
    text-decoration: underline;
  }
  .entry-head {
    margin-bottom: 1.6rem;
    padding-bottom: 1.3rem;
    border-bottom: 1px solid var(--line);
  }
  .entry-head h1 {
    font-size: var(--fs-2xl);
    line-height: 1.15;
    margin: 0 0 0.9rem;
  }
  .evidence-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.75rem;
    align-items: stretch;
    padding: 0.8rem 0;
    border-block: 1px solid var(--line);
  }
  .evidence-item {
    min-width: 7.5rem;
    display: grid;
    align-content: center;
    gap: 0.14rem;
    color: var(--ink-2);
    text-decoration: none;
  }
  .evidence-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.2;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .evidence-value {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: var(--fs-sm);
    line-height: 1.35;
    font-variant-numeric: tabular-nums;
  }
  .evidence-item--ok .dot {
    color: var(--ok);
  }
  .evidence-item--accent .dot,
  .evidence-item--source {
    color: var(--accent-2);
  }
  .evidence-item--warn {
    color: var(--warn);
  }
  .evidence-item--warn .dot {
    color: var(--warn);
  }
  .evidence-item--source:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
  }
  .evidence-badge {
    align-self: center;
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.2rem 0.45rem;
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.25;
    text-decoration: none;
  }
  .evidence-badge--warn {
    border-color: color-mix(in srgb, var(--warn) 44%, var(--line));
    color: var(--warn);
    background: var(--gold-soft);
  }
  .evidence-badge--link {
    color: var(--accent-2);
  }
  .evidence-badge--link:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .tagrow {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.65rem;
    margin-top: 0.8rem;
  }
  .tag {
    font-size: 0.72rem;
    color: var(--muted);
    font-family: var(--font-mono);
    overflow-wrap: anywhere;
  }

  /* right toc */
  .toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--line);
  }
  .toc li {
    margin: 0;
  }
  .toc li.lv3 a {
    padding-left: 1.5rem;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .toc a {
    display: block;
    padding: 0.22rem 0 0.22rem 0.85rem;
    margin-left: -1px;
    border-left: 2px solid transparent;
    text-decoration: none;
    color: var(--ink-2);
    line-height: 1.35;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .toc a:hover {
    color: var(--ink);
  }
  .toc a.active {
    color: var(--accent-2);
    border-left-color: var(--accent);
    font-weight: 600;
  }

  /* inline (mobile) toc */
  .toc-inline {
    display: none;
    margin: 0 0 1.6rem;
    border: 1px solid var(--line);
    border-radius: var(--r);
    background: var(--surface-2);
    padding: 0.5rem 0.9rem;
  }
  .toc-inline summary {
    cursor: pointer;
    font-weight: 650;
    font-size: var(--fs-sm);
    color: var(--ink-2);
  }
  .toc-inline ul {
    list-style: none;
    margin: 0.6rem 0 0.3rem;
    padding: 0;
  }
  .toc-inline li {
    margin: 0.15rem 0;
  }
  .toc-inline li.lv3 {
    padding-left: 1rem;
  }
  .toc-inline a {
    color: var(--ink-2);
    text-decoration: none;
    font-size: var(--fs-sm);
  }

  @media (max-width: 1080px) {
    .doc {
      grid-template-columns: var(--rail-left) minmax(0, 1fr);
    }
    .drail--right {
      display: none;
    }
    .toc-inline {
      display: block;
    }
  }
  @media (max-width: 820px) {
    .doc {
      grid-template-columns: minmax(0, 1fr);
      max-width: 46rem;
    }
    .drail--left {
      display: none;
    }
  }
</style>

<script>
  const links = Array.from(document.querySelectorAll('.toc--rail a')) as HTMLAnchorElement[];
  const map = new Map(links.map((a) => [decodeURIComponent((a.getAttribute('href') || '').slice(1)), a]));
  const heads = Array.from(document.querySelectorAll('.prose h2[id], .prose h3[id]'));
  if (heads.length && map.size && 'IntersectionObserver' in window) {
    let active: HTMLAnchorElement | null = null;
    const obs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const a = map.get((e.target as HTMLElement).id);
          if (a && a !== active) {
            active?.classList.remove('active');
            a.classList.add('active');
            active = a;
          }
        }
      },
      { rootMargin: '-78px 0px -68% 0px', threshold: 0 },
    );
    heads.forEach((h) => obs.observe(h));
  }
</script>
