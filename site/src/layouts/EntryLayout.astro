---
import Base from './Base.astro';
import { u, type Lang } from '../i18n/ui';
import { domainName } from '../i18n/domains';
import { entryDomain, entryRoute } from '../lib/routes';
interface Props { lang: Lang; entry: any; tr?: any }
const { lang, entry, tr } = Astro.props;
const fm = entry.data ?? {};
const route = entryRoute(entry);
const domain = entryDomain(entry);
const sources = Array.isArray(fm.sources) ? fm.sources : [];
const updated = fm.last_updated ? String(fm.last_updated).slice(0, 10) : null;
const title = (tr?.data?.title && String(tr.data.title)) || fm.title;
const machine = !!tr && tr.data?.status === 'machine';
const needsReview = tr?.data?.fidelity === 'needs_review';
const origHref = lang !== 'ja' ? u('ja', `${route}/`) : null;
---
<Base lang={lang} title={title}>
  <article class="entry">
    <div class="entry-meta">
      <a class="domain" href={u(lang, `domains/${domain}/`)}>{domainName(domain, lang)}</a>
      {fm.confidence && <span class="badge">confidence: {fm.confidence}</span>}
      {updated && <span class="badge">updated {updated}</span>}
      {sources.length > 0 && <span class="badge">{sources.length} sources</span>}
      {machine && <span class="badge mt">{lang === 'zh' ? '机器翻译' : 'machine-translated'}{needsReview ? ' ⚠' : ''}</span>}
      {origHref && <a class="badge orig" href={origHref}>{lang === 'zh' ? '原文(日)' : 'original (JA)'}</a>}
    </div>
    <h1>{title}</h1>
    <div class="prose"><slot /></div>
  </article>
</Base>

<style is:global>
  .entry { max-width: 52rem; }
  .entry-meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.8rem; margin-bottom: 0.5rem; }
  .entry-meta .domain { color: var(--accent); text-decoration: none; font-weight: 600; }
  .entry-meta .badge { color: var(--muted); border: 1px solid var(--line); border-radius: 999px; padding: 0.05rem 0.6rem; }
  .entry-meta .badge.mt { color: #9a6700; border-color: #e0c060; background: #fff8e0; }
  .entry-meta a.badge.orig { color: var(--accent); text-decoration: none; }
  .entry h1 { font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.1rem); line-height: 1.25; margin: 0.2rem 0 1.5rem; letter-spacing: -0.01em; }

  .prose { font-size: 1rem; }
  .prose h2 { font-size: 1.3rem; margin: 2.2rem 0 0.6rem; padding-bottom: 0.3rem; border-bottom: 1px solid var(--line); }
  .prose h3 { font-size: 1.08rem; margin: 1.6rem 0 0.4rem; }
  .prose p { margin: 0.7rem 0; }
  .prose a { color: var(--accent); }
  .prose ul, .prose ol { padding-left: 1.3rem; }
  .prose li { margin: 0.25rem 0; }
  .prose blockquote { margin: 1rem 0; padding: 0.5rem 1rem; border-left: 3px solid var(--accent); background: var(--soft); color: #333; border-radius: 0 6px 6px 0; }
  .prose code { background: var(--soft); padding: 0.1rem 0.35rem; border-radius: 4px; font-size: 0.9em; }
  .prose pre { background: #0d1117; color: #e6edf3; padding: 1rem; border-radius: 8px; overflow-x: auto; }
  .prose pre code { background: none; padding: 0; }

  .prose table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9rem; display: block; overflow-x: auto; }
  .prose th, .prose td { border: 1px solid var(--line); padding: 0.4rem 0.6rem; text-align: left; vertical-align: top; }
  .prose thead th { background: var(--soft); position: sticky; top: 0; }

  /* wikilink（解決済 = リンク / 未解決 = broken span） */
  a.wl { color: var(--accent); text-decoration: none; border-bottom: 1px solid color-mix(in srgb, var(--accent) 35%, transparent); cursor: pointer; }
  a.wl:hover { border-bottom-color: var(--accent); }
  .wl-broken { color: var(--muted); border-bottom: 1px dotted var(--muted); cursor: help; }
  /* provenance 置信度徽章 */
  .prov { font-size: 0.6em; vertical-align: super; margin-left: 1px; }
  .prov::before { content: '●'; }
  .prov-extracted::before { color: #0a0; }   /* 已溯源事实 */
  .prov-inferred::before { color: #e90; }     /* 推断 */
  .prov-ambiguous::before { color: #d00; }    /* 存疑 */
</style>
